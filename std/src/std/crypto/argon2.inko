# The Argon2id password function.
#
# This module provides an implementation of Argon2id as specified in
# [RFC 9106](https://www.rfc-editor.org/rfc/rfc9106.html), and using the
# following sources as an additional reference:
#
# - <https://git.sr.ht/~sircmpwn/hare/tree/master/item/crypto/argon2/argon2.ha>
# - <https://github.com/odin-lang/Odin/blob/master/core/crypto/argon2id/argon2id.odin>
# - <https://github.com/bwesterb/argon2pure/blob/master/argon2pure.py>
# - <https://en.wikipedia.org/wiki/Argon2#Algorithm>
#
# This module _does not_ provide an implementation of Argon2d or Argon2i, only
# Argon2id is implemented.
#
# For more information refer to the documentation of the `Argon2` type.
import std.alloc
import std.base64 (Decoder, Encoder)
import std.bytes (Bytes, Slice, ToSlice)
import std.cmp (Equal, min)
import std.crypto.blake2 (Blake2b, DIGEST_SIZE)
import std.crypto.math (U64, to_u32)
import std.drop (Drop)
import std.endian.little
import std.fmt (Format, Formatter)
import std.int
import std.ptr
import std.string (ToString)

let U32_MAX = 2 ** 32 - 1

# The Argon2 version.
let VERSION = 0x13

# The type tag to use for Argon2id.
let TYPE_2ID = 2

# The size (in bytes) of a single block.
let BLOCK_SIZE = 1024
let BLOCK_INTS = 128
let SLICES = 4

fn invalid_memory_size(value: Int) -> Never {
  panic('the memory size ${value} bytes is invalid')
}

fn invalid_iterations(value: Int) -> Never {
  panic('the iteration count ${value} is invalid')
}

fn invalid_output_size(value: Int) -> Never {
  panic('the output size ${value} is invalid')
}

fn invalid_secret_size(value: Int) -> Never {
  panic('the secret key size ${value} is invalid')
}

fn invalid_associated_data_size(value: Int) -> Never {
  panic('the associated data size ${value} is invalid')
}

fn invalid_parallel(value: Int) -> Never {
  panic('the amount of parallel processes ${value} is invalid')
}

fn invalid_password_or_salt_size -> Never {
  panic('passwords and salts must not be larger than ${U32_MAX} bytes')
}

fn hash_into[B: Bytes](hasher: Blake2b, buffer: ref B) {
  let hash = hasher.finish.into_byte_array

  alloc.copy(from: hash.pointer, to: buffer.pointer, size: hash.size)
}

fn perm(
  x0: Pointer[U64],
  x1: Pointer[U64],
  x2: Pointer[U64],
  x3: Pointer[U64],
  x4: Pointer[U64],
  x5: Pointer[U64],
  x6: Pointer[U64],
  x7: Pointer[U64],
  x8: Pointer[U64],
  x9: Pointer[U64],
  x10: Pointer[U64],
  x11: Pointer[U64],
  x12: Pointer[U64],
  x13: Pointer[U64],
  x14: Pointer[U64],
  x15: Pointer[U64],
) {
  mix(x0, x4, x8, x12)
  mix(x1, x5, x9, x13)
  mix(x2, x6, x10, x14)
  mix(x3, x7, x11, x15)

  mix(x0, x5, x10, x15)
  mix(x1, x6, x11, x12)
  mix(x2, x7, x8, x13)
  mix(x3, x4, x9, x14)
}

fn mix(a: Pointer[U64], b: Pointer[U64], c: Pointer[U64], d: Pointer[U64]) {
  a.0 = a.0 + b.0 + (U64(2) * a.0.to_u32 * b.0.to_u32)
  d.0 = (d.0 ^ a.0).rotate_right(32)
  c.0 = c.0 + d.0 + (U64(2) * c.0.to_u32 * d.0.to_u32)
  b.0 = (b.0 ^ c.0).rotate_right(24)

  a.0 = a.0 + b.0 + (U64(2) * a.0.to_u32 * b.0.to_u32)
  d.0 = (d.0 ^ a.0).rotate_right(16)
  c.0 = c.0 + d.0 + (U64(2) * c.0.to_u32 * d.0.to_u32)
  b.0 = (b.0 ^ c.0).rotate_right(63)
}

fn compress(dest: BlockPtr, x: BlockPtr, y: BlockPtr, xor: Bool) {
  let r_buf = Block()
  let r = BlockPtr(mut r_buf)

  xor_block(r, x, y)

  let z_buf = r_buf
  let z = BlockPtr(mut z_buf)

  for i in 0.until(128).step_by(16) {
    perm(
      z.at(i),
      z.at(i + 1),
      z.at(i + 2),
      z.at(i + 3),
      z.at(i + 4),
      z.at(i + 5),
      z.at(i + 6),
      z.at(i + 7),
      z.at(i + 8),
      z.at(i + 9),
      z.at(i + 10),
      z.at(i + 11),
      z.at(i + 12),
      z.at(i + 13),
      z.at(i + 14),
      z.at(i + 15),
    )
  }

  for i in 0.until(16).step_by(2) {
    perm(
      z.at(i),
      z.at(i + 1),
      z.at(i + 16),
      z.at(i + 17),
      z.at(i + 32),
      z.at(i + 33),
      z.at(i + 48),
      z.at(i + 49),
      z.at(i + 64),
      z.at(i + 65),
      z.at(i + 80),
      z.at(i + 81),
      z.at(i + 96),
      z.at(i + 97),
      z.at(i + 112),
      z.at(i + 113),
    )
  }

  if xor { xor_block(r, r, dest) }

  xor_block(dest, z, r)
}

fn xor_block(dest: BlockPtr, x: BlockPtr, y: BlockPtr) {
  for i in 0.until(BLOCK_INTS) { dest.set(i, x.get(i) ^ y.get(i)) }
}

fn xor_bytes(dest: BlockPtr, x: BlockPtr, y: BlockPtr) {
  for i in 0.until(BLOCK_SIZE) { dest.set_u8(i, x.u8(i) ^ y.u8(i)) }
}

fn zero_block(pointer: Pointer[Block]) {
  alloc.zero(pointer as Pointer[Uint8], BLOCK_SIZE)
}

